# Personal Finance Assistant — Backend environment configuration
# Copy this file to ".env" and adjust the values for your environment.
# The .env file is git-ignored and must NEVER be committed.

# --- Database ---
# SQLite (default, good for local development).
# Leave this commented out to use the built-in default, which resolves to an
# ABSOLUTE path at backend/finance.db regardless of where you launch uvicorn.
# Only set it if you want a custom location — and prefer an absolute path, because
# a relative path like "sqlite:///./finance.db" creates a NEW empty database in
# whatever folder you start the server from.
# DATABASE_URL=sqlite:///C:/full/path/to/backend/finance.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/finance

# --- Security ---
# Generate a strong random value, e.g. `python -c "import secrets; print(secrets.token_hex(32))"`
SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CORS ---
# Primary frontend URL.
FRONTEND_URL=http://localhost:5173
# Comma-separated list of additional allowed origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Development-only escape hatch to allow all origins (NEVER use in production):
# CORS_ALLOW_ALL=false

# --- AI (optional) ---
# The chatbot supports multiple backends. Pick ONE and uncomment it.
#
# Ollama (LOCAL, FREE, UNLIMITED, no key). Install https://ollama.com then
#   `ollama pull llama3.1` and keep `ollama serve` running:
# AI_PROVIDER=openai
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=llama3.1
#
# Groq (FREE key, fast, rate-limited). Key: https://console.groq.com/keys
# AI_PROVIDER=openai
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_API_KEY=gsk_your_groq_key_here
# AI_MODEL=llama-3.1-8b-instant
#
# Anthropic Claude (PAID). Key: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
#
# When nothing is set, the app falls back to rule-based logic and stays functional.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
AI_PROVIDER=
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
